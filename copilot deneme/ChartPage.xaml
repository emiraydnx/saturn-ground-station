<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="copilot_deneme.ChartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:copilot_deneme"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:viewmodels="using:copilot_deneme.ViewModels"
    mc:Ignorable="d"
    UseLayoutRounding="True">

    <Page.Resources>
        <Style x:Key="ChartCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource SecondaryBrush}"/>
            <Setter Property="Shadow">
                <Setter.Value>
                    <ThemeShadow/>
                </Setter.Value>
            </Setter>
            <Setter Property="Margin" Value="8"/>
        </Style>
        
        <Style x:Key="ChartTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,12,0,8"/>
        </Style>
        
        <Style x:Key="ChartIconStyle" TargetType="FontIcon">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- GPS Koordinat stilleri -->
        <Style x:Key="GpsCoordTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#2A2D2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Margin" Value="4"/>
        </Style>

        <Style x:Key="GpsLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1A1A2E" Offset="0"/>
                <GradientStop Color="#16213E" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{StaticResource CardBrush}" 
                CornerRadius="16" 
                Margin="16,16,16,8"
                BorderBrush="{StaticResource AccentBrush}" 
                BorderThickness="1"
                Translation="0,0,8">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Margin="20,16">
                <FontIcon Glyph="&#xE9D2;" 
                          Foreground="{StaticResource AccentBrush}" 
                          FontSize="24" 
                          Margin="0,0,12,0"/>
                <TextBlock Text="Telemetri Grafikleri ve GPS Koordinatları"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="White"/>
                <Ellipse Width="12" Height="12" 
                         Fill="{StaticResource SuccessBrush}" 
                         Margin="12,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- GPS Koordinat Paneli -->
        <Border Grid.Row="1"
                Background="{StaticResource CardBrush}"
                CornerRadius="16"
                Margin="16,8,16,8"
                BorderBrush="{StaticResource SecondaryBrush}"
                BorderThickness="1"
                Translation="0,0,8">
            <Grid Margin="20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Roket GPS Koordinatları -->
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <FontIcon Glyph="&#xE81C;" 
                                  Foreground="#FF6B73" 
                                  FontSize="18" 
                                  Margin="0,0,8,0"/>
                        <TextBlock Text="🚀 Roket GPS Koordinatları" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="White"/>
                    </StackPanel>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Enlem:" Style="{StaticResource GpsLabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" 
                                 x:Name="RocketLatitudeTextBox" 
                                 Text="38.536000"
                                 Style="{StaticResource GpsCoordTextBoxStyle}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Boylam:" Style="{StaticResource GpsLabelStyle}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" 
                                 x:Name="RocketLongitudeTextBox" 
                                 Text="27.022000"
                                 Style="{StaticResource GpsCoordTextBoxStyle}"/>
                    </Grid>
                </StackPanel>

                <!-- Payload GPS Koordinatları -->
                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <FontIcon Glyph="&#xEB42;" 
                                  Foreground="#4CAF50" 
                                  FontSize="18" 
                                  Margin="0,0,8,0"/>
                        <TextBlock Text="📡 Payload GPS Koordinatları" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="White"/>
                    </StackPanel>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Enlem:" Style="{StaticResource GpsLabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" 
                                 x:Name="PayloadLatitudeTextBox" 
                                 Text="38.536000"
                                 Style="{StaticResource GpsCoordTextBoxStyle}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Boylam:" Style="{StaticResource GpsLabelStyle}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" 
                                 x:Name="PayloadLongitudeTextBox" 
                                 Text="27.022000"
                                 Style="{StaticResource GpsCoordTextBoxStyle}"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Charts Grid -->
        <Grid Grid.Row="2" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- İrtifa Chart -->
            <Border Grid.Column="0" Grid.Row="0" 
                    Style="{StaticResource ChartCardStyle}"
                    Translation="0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" 
                                HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE81C;" 
                                  Foreground="{StaticResource AccentBrush}"
                                  Style="{StaticResource ChartIconStyle}"/>
                        <TextBlock Text="İrtifa (m)" 
                                   Style="{StaticResource ChartTitleStyle}"/>
                    </StackPanel>
                    
                    <lvc:CartesianChart Grid.Row="1"
                                        x:Name="AltitudeSeries"
                                        Series="{x:Bind ViewModel.AltitudeSeries, Mode=OneWay}"
                                        LegendPosition="Bottom"
                                        Margin="8"/>
                </Grid>
            </Border>

            <!-- İvme Chart -->
            <Border Grid.Column="1" Grid.Row="0" 
                    Style="{StaticResource ChartCardStyle}"
                    Translation="0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" 
                                HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE9CE;" 
                                  Foreground="{StaticResource PrimaryBrush}"
                                  Style="{StaticResource ChartIconStyle}"/>
                        <TextBlock Text="İvme (m/s²)" 
                                   Style="{StaticResource ChartTitleStyle}"/>
                    </StackPanel>
                    
                    <lvc:CartesianChart Grid.Row="1"
                                        x:Name="AccelSeries"
                                        Series="{x:Bind ViewModel.AccelerationSeries, Mode=OneWay}"
                                        LegendPosition="Bottom"
                                        Margin="8"/>
                </Grid>
            </Border>

            <!-- Hız Chart -->
            <Border Grid.Column="2" Grid.Row="0" 
                    Style="{StaticResource ChartCardStyle}"
                    Translation="0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" 
                                HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE9F3;" 
                                  Foreground="{StaticResource SuccessBrush}"
                                  Style="{StaticResource ChartIconStyle}"/>
                        <TextBlock Text="Hız (m/s)" 
                                   Style="{StaticResource ChartTitleStyle}"/>
                    </StackPanel>
                    
                    <lvc:CartesianChart Grid.Row="1"
                                        x:Name="SpeedSeries"
                                        Series="{x:Bind ViewModel.SpeedSeries, Mode=OneWay}"
                                        LegendPosition="Bottom"
                                        Margin="8"/>
                </Grid>
            </Border>

            <!-- Sıcaklık Chart -->
            <Border Grid.Column="0" Grid.Row="1" 
                    Style="{StaticResource ChartCardStyle}"
                    Translation="0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" 
                                HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE9CA;" 
                                  Foreground="#FF6B73"
                                  Style="{StaticResource ChartIconStyle}"/>
                        <TextBlock Text="Sıcaklık (°C)" 
                                   Style="{StaticResource ChartTitleStyle}"/>
                    </StackPanel>
                    
                    <lvc:CartesianChart Grid.Row="1"
                                        x:Name="TempSeries"
                                        Series="{x:Bind ViewModel.TemperatureSeries, Mode=OneWay}"
                                        LegendPosition="Bottom"
                                        Margin="8"/>
                </Grid>
            </Border>

            <!-- Basınç Chart -->
            <Border Grid.Column="1" Grid.Row="1" 
                    Style="{StaticResource ChartCardStyle}"
                    Translation="0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" 
                                HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE9C9;" 
                                  Foreground="#9C88FF"
                                  Style="{StaticResource ChartIconStyle}"/>
                        <TextBlock Text="Basınç (hPa)" 
                                   Style="{StaticResource ChartTitleStyle}"/>
                    </StackPanel>
                    
                    <lvc:CartesianChart Grid.Row="1"
                                        x:Name="PressureySeries"
                                        Series="{x:Bind ViewModel.PressureSeries, Mode=OneWay}"
                                        LegendPosition="Bottom"
                                        Margin="8"/>
                </Grid>
            </Border>

            <!-- Nem Chart -->
            <Border Grid.Column="2" Grid.Row="1" 
                    Style="{StaticResource ChartCardStyle}"
                    Translation="0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" 
                                HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xEB42;" 
                                  Foreground="#00D4FF"
                                  Style="{StaticResource ChartIconStyle}"/>
                        <TextBlock Text="Nem (%)" 
                                   Style="{StaticResource ChartTitleStyle}"/>
                    </StackPanel>
                    
                    <lvc:CartesianChart Grid.Row="1"
                                        x:Name="HumiditySeries"
                                        Series="{x:Bind ViewModel.HumiditySeries, Mode=OneWay}"
                                        LegendPosition="Bottom"
                                        Margin="8"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
